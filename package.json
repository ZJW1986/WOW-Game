    "react-dom": "^19.0.0",
    "sharp": "^0.35.2",
    "three": "^0.184.0",
    "typescript": "^5.5.0",
    "vite": "^7.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
